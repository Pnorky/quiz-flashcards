{
  "name": "quiz-game",
  "version": "1.0.0",
  "private": true,
  "main": "index.html",
  "dependencies": {
    "basecoat-css": "0.3.11",
    "http-server": "^14.1.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.4.5"
  },
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i ./tailwind-basecoat.css -o ./resource/app/compiled.css",
    "build": "npm run build:css && npx tsc",
    "watch": "npx tsc --watch --preserveWatchOutput",
    "serve": "npm run build:css && npx tsc && npx http-server ."
  }
}
